{
  "name": "local-pc-assistant",
  "version": "1.0.0",
  "description": "本地电脑助手 - 文件整理、局域网传输、C盘优化",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "dist": "npm run build:win"
  },
  "keywords": [
    "electron",
    "file-manager",
    "disk-optimizer",
    "lan-transfer"
  ],
  "author": "尽为一土 <spring60@vip.qq.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "sqlite3": "^5.1.6",
    "ws": "^8.14.2",
    "qrcode": "^1.5.3",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.yituu.local-pc-assistant",
    "productName": "本地电脑助手",
    "directories": {
      "output": "../dist",
      "app": "."
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "types/**/*",
      "../assets/**/*",
      "../tools/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../tools/wiztree",
        "to": "tools/wiztree"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "../assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "本地电脑助手"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "../assets/icon.png"
    }
  }
}
